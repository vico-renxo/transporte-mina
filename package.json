{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "prisma generate && prisma migrate deploy",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
